{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2024", "ESNext.Array"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vitest/importMeta", "node"]
  },
  "include": ["src/**/*", "rolldown.config.ts"]
}
